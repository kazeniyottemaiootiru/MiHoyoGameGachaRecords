<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
		<section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
	</configSections>
<log4net>
  <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
	<file value="Logs/logfile.log" />
	<appendToFile value="true" />
	<!-- Use date-based rolling and keep ~30 days of logs (approx. one month) -->
	<rollingStyle value="Date" />
	<!-- Keep the most recent 15 rolled files (one per day) -->
	<maxSizeRollBackups value="15" />
	<!-- Pattern for dated log files: logfile.log.YYYY-MM-DD-HH-MM-SS -> creates a new file for each start (timestamped) -->
	<datePattern value="'.'yyyy-MM-dd-HH-mm-ss" />
	<!-- Include the date in the current file name so backups are by date -->
	<staticLogFileName value="false" />
	<!-- Preserve the .log extension when appending the date -->
	<preserveLogFileNameExtension value="true" />
	<layout type="log4net.Layout.PatternLayout">
	  <!--<conversionPattern value="%date [%thread] %-5level %logger - %message%newline" />-->
		<conversionPattern value="%-5level %date %logger -%message%newline" />
	</layout>
  </appender>
  <!-- A second appender that accumulates all logs into a single file (merged previous logs) -->
  <!--<appender name="CombinedFileAppender" type="log4net.Appender.FileAppender">
    <file value="Logs/all.log" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%-5level %date %logger -%message%newline" />
    </layout>
  </appender>-->

  <root>
    <level value="WARN" />
    <appender-ref ref="RollingFileAppender" />
    <appender-ref ref="CombinedFileAppender" />
  </root>
	</log4net>
	</configuration>