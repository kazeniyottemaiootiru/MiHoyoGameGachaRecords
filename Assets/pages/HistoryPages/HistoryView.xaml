<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MiHoyoGameGachaRecords.Assets.pages.HistoryPages.HistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MiHoyoGameGachaRecords.Assets.pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20" Spacing="16">

            <!-- 顶部说明 -->
            <TextBlock x:Name="InfomationText"
                       FontSize="28"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

            <!-- 查询区域 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
                <ComboBox x:Name="FilterComboBox"
                          Width="220"/>
                <Button x:Uid="Common/Analysis"
                        Click="GetMems_Click"/>
            </StackPanel>

            <!-- 列表 -->
            <ItemsControl x:Name="MemList" HorizontalAlignment="Center">
                <!--<aviation="1">-->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="600"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                           FontSize="18"/>

                                <Grid Grid.Column="1"
                                  Height="28"
                                  Background="#FFEFEFEF"
                                  CornerRadius="4">
                                    <Border Width="{Binding BarWidth}"
                                        Background="{Binding BarBrush}"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"/>
                                    <TextBlock Text="{Binding Value}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                               FontSize="15"
                                           FontWeight="Bold"/>
                                </Grid>

                                <TextBlock Grid.Column="2"
                                       Text="{Binding ExistMark}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                       Foreground="Red"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
